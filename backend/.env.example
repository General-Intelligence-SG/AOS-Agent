# AOS 环境配置
# 复制此文件为 .env 并填入实际值

# ── LLM 配置（必填其一）──
LLM_PROVIDER=openai
# 可选: openai / deepseek / qwen / ollama
LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=          # 自定义 API 地址（deepseek/qwen 已有默认值）
LLM_MODEL=gpt-4o-mini
# LLM_EMBEDDING_MODEL=text-embedding-3-small

# ── 应用配置 ──
# HOST=0.0.0.0
# PORT=8000
# DEBUG=true

# ── 安全配置 ──
# EXPORT_ENCRYPTION_KEY=your-encryption-key
